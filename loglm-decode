#!/usr/bin/env bash
set -euo pipefail

usage() {
  local cmd
  cmd="$(basename "$0")"
  cat <<'EOF'
Usage:
EOF
  cat <<EOF
  $cmd [options] <input_file>...

Options:
  -o, --output <file>  Output file path (single input only)
  --keep-overlap       Keep overlapping context instead of trimming it
  -h, --help           Show this help

Behavior:
  - Positional arguments are always treated as input files.
  - Without -o, each input is written to "<input_basename>.decoded.txt".
    Example: logs/codex-log-20260217.txt -> logs/codex-log-20260217.decoded.txt
  - By default, overlapping leading context shared with the previous log
    in the same series is trimmed from the current decoded output.
EOF
}

derive_output_path() {
  local in_file="$1"
  local dir base stem
  dir="$(dirname "$in_file")"
  base="$(basename "$in_file")"
  stem="${base%.*}"
  if [[ "$stem" == "$base" ]]; then
    printf '%s/%s.decoded.txt\n' "$dir" "$base"
  else
    printf '%s/%s.decoded.txt\n' "$dir" "$stem"
  fi
}

decode_raw_to_file() {
  local in_file="$1"
  local out_file="$2"
  local tmp_file
  local profile base
  tmp_file="$(/usr/bin/mktemp)"
  trap 'rm -f "$tmp_file"' RETURN

  profile="${LOGLM_DECODE_PROFILE:-auto}"
  if [[ "$profile" == "auto" ]]; then
    base="$(basename "$in_file" | tr '[:upper:]' '[:lower:]')"
    if [[ "$base" == *claude* ]]; then
      profile="claude"
    elif [[ "$base" == *gemini* ]]; then
      profile="gemini"
    else
      profile="default"
    fi
  fi

  LOGLM_DECODE_PROFILE="$profile" perl -e '
use strict;
use warnings;
use Encode qw(decode encode FB_DEFAULT);

binmode(STDIN);
binmode(STDOUT);

my $NORMAL = 0;
my $ESC = 1;
my $CSI = 2;
my $OSC = 3;
my $OSC_ESC = 4;
my $DCS = 5;
my $DCS_ESC = 6;

my $state = $NORMAL;
my $out = q{};
my $c;
my $pending_cr = 0;
my $csi_param = q{};
my $profile = $ENV{LOGLM_DECODE_PROFILE} // q{};
my $is_claude = ($profile eq "claude") ? 1 : 0;
my $is_gemini = ($profile eq "gemini") ? 1 : 0;

while (read(STDIN, $c, 1)) {
  my $b = ord($c);

  if ($state == $NORMAL) {
    if ($pending_cr) {
      if ($b == 0x0A) {
        # CR+LF (including CR+CR+LF): single newline.
        $out .= "\n";
        $pending_cr = 0;
        next;
      } elsif ($b == 0x0D) {
        # Consecutive CRs (e.g. Claude Code uses \r\r\n): ignore extra CR.
        next;
      } else {
        # Lone CR: move to start of current line (overwrite semantics).
        my $last_nl = rindex($out, "\n");
        if ($last_nl >= 0) {
          substr($out, $last_nl + 1) = q{};
        } else {
          $out = q{};
        }
        $pending_cr = 0;
        # Fall through to process $b normally.
      }
    }

    if ($b == 0x1B) { # ESC
      $state = $ESC;
    } elsif ($b == 0x08) { # BS
      substr($out, -1, 1, q{}) if length($out) > 0;
    } elsif ($b == 0x0D) { # CR
      # Defer until next byte so CRLF does not become double newline.
      $pending_cr = 1;
    } elsif ($b == 0x0A || $b == 0x09) { # LF/TAB
      $out .= $c;
    } elsif ($b < 0x20 || $b == 0x7F) {
      # drop other C0 controls and DEL
    } else {
      $out .= $c;
    }
    next;
  }

  if ($state == $ESC) {
    if ($b == ord("[")) {
      $state = $CSI;
      $csi_param = q{};
    } elsif ($b == ord("]")) {
      $state = $OSC;
    } elsif ($b == ord("P")) {
      $state = $DCS;
    } else {
      # single escape sequence
      $state = $NORMAL;
    }
    next;
  }

  if ($state == $CSI) {
    if ($b >= 0x40 && $b <= 0x7E) {
      # CSI final byte.
      if ($b == ord("C")) {
        # Cursor Forward: many TUIs (e.g. Claude Code/Ink) use ESC[nC
        # instead of literal spaces for inter-word/column spacing.
        my $n = ($csi_param =~ /^(\d+)$/) ? int($csi_param) : 1;
        $out .= " " x $n if $n > 0;
      }
      $state = $NORMAL;
    } else {
      $csi_param .= $c;
    }
    next;
  }

  if ($state == $OSC) {
    if ($b == 0x07) { # BEL
      $state = $NORMAL;
    } elsif ($b == 0x1B) {
      $state = $OSC_ESC;
    }
    next;
  }

  if ($state == $OSC_ESC) {
    if ($b == ord("\\")) {
      $state = $NORMAL;
    } else {
      $state = $OSC;
    }
    next;
  }

  if ($state == $DCS) {
    if ($b == 0x1B) {
      $state = $DCS_ESC;
    }
    next;
  }

  if ($state == $DCS_ESC) {
    if ($b == ord("\\")) {
      $state = $NORMAL;
    } else {
      $state = $DCS;
    }
    next;
  }
}

if ($pending_cr) {
  $out .= "\n";
}

# Trim trailing whitespace from each line (leftover from ESC[nC padding).
$out =~ s/[ \t]+\n/\n/g;
$out =~ s/[ \t]+\z//;

my $text = decode("UTF-8", $out, FB_DEFAULT);
my @lines = split /\n/, $text, -1;
my @merged = ();
if ($is_claude) {
  # Merge "staircase" input echoes common in Claude TUI redraws.
  for (my $i = 0; $i < @lines; ) {
    my @tokens = ();
    my @indents = ();
    my $j = $i;
    my $consumed_any = 0;

    while ($j < @lines) {
      my $line = $lines[$j];
      if ($line eq q{}) {
        $j++;
        next if @tokens > 0;
        last;
      }

      last unless $line =~ /^(\s*)(\S.*?)\s*$/;
      my $indent = length($1);
      my $token = $2;
      last if $token =~ /\s/;
      last if length($token) > 24;
      last if @indents && $indent < $indents[-1];

      push @indents, $indent;
      push @tokens, $token;
      $consumed_any = 1;
      $j++;
      last if @tokens >= 300;
    }

    if (@tokens >= 4) {
      my $inc = 0;
      for (my $k = 1; $k < @indents; $k++) {
        $inc++ if $indents[$k] > $indents[$k - 1];
      }
      if ($inc >= int(@tokens * 0.6)) {
        push @merged, join(q{}, @tokens);
        $i = $j;
        next;
      }
    }

    if ($consumed_any) {
      push @merged, $lines[$i];
      $i++;
    } else {
      push @merged, $lines[$i];
      $i++;
    }
  }
} elsif ($is_gemini) {
  my @normalized = ();
  my $pending_prompt;
  my $last_emitted_prompt;

  for my $raw (@lines) {
    my $line = $raw;

    # Drop box borders produced by Gemini TUI redraws.
    next if $line =~ /^\s*[\p{Block=Box_Drawing}]+\s*$/u;

    # Unwrap boxed lines: "в”‚ ... в”‚" -> "..."
    if ($line =~ /^\s*\p{Block=Box_Drawing}(.*)\p{Block=Box_Drawing}\s*$/u) {
      $line = $1;
      $line =~ s/^\s+//;
      $line =~ s/\s+$//;
    } else {
      $line =~ s/\s+$//;
    }

    # Drop frequent transient UI lines.
    if (
      $line eq q{} ||
      $line =~ /Waiting for auth/i ||
      $line =~ /Gemini CLI update available!/ ||
      $line =~ /Installed via Homebrew\./ ||
      $line =~ /^loglm-gemini$/ ||
      $line =~ /^no sandbox \(see \/docs\)$/ ||
      $line =~ /no sandbox \(see \/docs\)/ ||
      $line =~ /^gemini-[[:alnum:]._-]+ \(\d+% context left\)$/ ||
      $line =~ /^[\x{2800}-\x{28FF}]\s+/u ||
      $line =~ /^\S.*\(esc to cancel,\s*\d+s\)$/ ||
      $line =~ /^>\s*Type your message or \@path\/to\/file$/
    ) {
      next;
    }

    # Merge staircase-style prompt redraws into one line.
    if ($line =~ /^>\s*(.*)$/) {
      my $p = $1;
      $p =~ s/^\s+//;
      $p =~ s/\s+$//;
      if (!defined $pending_prompt) {
        $pending_prompt = $p;
        next;
      }
      if ($p =~ /^\Q$pending_prompt\E/ || $pending_prompt =~ /^\Q$p\E/) {
        # Continue tracking while user edits (both extension and backspace).
        $pending_prompt = $p;
        next;
      }
      if (
        $pending_prompt ne q{} &&
        (length($pending_prompt) >= 4 || $pending_prompt =~ m{^/}) &&
        (!defined $last_emitted_prompt || $last_emitted_prompt ne $pending_prompt)
      ) {
        push @normalized, "> $pending_prompt";
        $last_emitted_prompt = $pending_prompt;
      }
      $pending_prompt = $p;
      next;
    }

    if (defined $pending_prompt) {
      if ($line eq $pending_prompt) {
        next;
      }
      if (
        $pending_prompt ne q{} &&
        (length($pending_prompt) >= 4 || $pending_prompt =~ m{^/}) &&
        (!defined $last_emitted_prompt || $last_emitted_prompt ne $pending_prompt)
      ) {
        push @normalized, "> $pending_prompt";
        $last_emitted_prompt = $pending_prompt;
      }
      undef $pending_prompt;
    }
    if (defined $last_emitted_prompt && $line eq $last_emitted_prompt) {
      next;
    }

    push @normalized, $line;
  }

  if (defined $pending_prompt) {
    if (
      $pending_prompt ne q{} &&
      (length($pending_prompt) >= 4 || $pending_prompt =~ m{^/}) &&
      (!defined $last_emitted_prompt || $last_emitted_prompt ne $pending_prompt)
    ) {
      push @normalized, "> $pending_prompt";
    }
  }

  @merged = @normalized;
} else {
  @merged = @lines;
}

# Collapse noisy consecutive duplicates and repeated blank lines.
my @dedup = ();
my $prev_cmp = undef;
my $blank_run = 0;
for my $line (@merged) {
  my $line_out = $line;
  if ($line eq q{}) {
    next if $is_claude && defined $prev_cmp && ($prev_cmp eq "(thinking)" || $prev_cmp eq "(status)" || $prev_cmp eq "(spinner)");
    $blank_run++;
    next if $blank_run > 1;
  } else {
    $blank_run = 0;
  }

  my $cmp = $line;
  if ($is_claude) {
    $cmp =~ s/^\s+//;
    $cmp =~ s/\s+$//;
    if ($cmp =~ /\(thinking\)/) {
      $cmp = "(thinking)";
      $line_out = "(thinking)";
    }
    if (
      $cmp ne "(thinking)" &&
      length($cmp) <= 80 &&
      $cmp =~ /ing/i &&
      $cmp !~ m{[/:\\]}
    ) {
      $cmp = "(status)";
      $line_out = "(status)";
    }
    $cmp = "(spinner)" if $cmp =~ /^[В·вњўвњівњ¶вњ»вњЅвЏє]+$/;
    if (
      defined $prev_cmp &&
      $prev_cmp eq "(status)" &&
      $cmp =~ /^[[:alpha:][:space:]вЂ¦-]{1,24}$/
    ) {
      $cmp = "(status)";
      $line_out = "(status)";
    }
    if (
      defined $prev_cmp &&
      ($prev_cmp eq "(status)" || $prev_cmp eq "(spinner)" || $prev_cmp eq "(thinking)") &&
      $cmp =~ /[[:alpha:]]/ &&
      $cmp =~ /^[В·вњўвњівњ¶вњ»вњЅвЏє[:space:][:alnum:]вЂ¦-]{1,24}$/
    ) {
      $cmp = "(status)";
      $line_out = "(status)";
    }
    if (
      $cmp =~ /[[:alpha:]][[:space:]]+[[:alpha:]]/ &&
      length($cmp) <= 24 &&
      $cmp =~ /^[В·вњўвњівњ¶вњ»вњЅвЏє[:space:][:alnum:]вЂ¦-]+$/
    ) {
      $cmp = "(status)";
      $line_out = "(status)";
    }
    if (
      length($cmp) <= 28 &&
      ($cmp =~ /[в†‘в†“вЂ¦]/ || $cmp =~ /[В·вњўвњівњ¶вњ»вњЅвЏє]/) &&
      $cmp =~ /^[В·вњўвњівњ¶вњ»вњЅвЏєв†‘в†“[:space:][:alnum:]вЂ¦-]+$/
    ) {
      $cmp = "(status)";
      $line_out = "(status)";
    }
  } elsif ($is_gemini) {
    $cmp =~ s/^\s+//;
    $cmp =~ s/\s+$//;
    # Startup banner art is mostly decorative and very noisy.
    if ($cmp =~ /^[[:space:]\p{Block=Block_Elements}]+$/u) {
      next;
    }
  }

  if (
    $is_claude &&
    $cmp eq "(spinner)" &&
    defined $prev_cmp &&
    ($prev_cmp eq "(spinner)" || $prev_cmp eq "(thinking)" || $prev_cmp eq "(status)")
  ) {
    next;
  }
  next if defined $prev_cmp && $cmp eq $prev_cmp && $cmp ne q{};
  push @dedup, $line_out;
  $prev_cmp = $cmp;
}
$out = join("\n", @dedup);

# Collapse 3+ consecutive newlines to 2 (at most one blank line).
$out =~ s/\n{3,}/\n\n/g;

print STDOUT encode("UTF-8", $out);
' < "$in_file" > "$tmp_file"

  mv "$tmp_file" "$out_file"
  trap - RETURN

  echo "decoded: $in_file -> $out_file"
}

find_previous_log_in_series() {
  local in_file="$1"
  local dir base prefix prev candidate candidate_base
  dir="$(dirname "$in_file")"
  base="$(basename "$in_file")"

  if [[ ! "$base" =~ ^(loglm-[^-]+-log-).+\.txt$ ]]; then
    return 1
  fi
  prefix="${BASH_REMATCH[1]}"

  while IFS= read -r candidate; do
    candidate_base="$(basename "$candidate")"
    [[ "$candidate_base" == *.decoded.txt ]] && continue
    [[ "$candidate_base" == "$base" ]] && continue
    if [[ "$candidate_base" < "$base" ]]; then
      prev="$candidate"
    fi
  done < <(find "$dir" -maxdepth 1 -type f -name "${prefix}*.txt" | LC_ALL=C sort)

  [[ -n "${prev:-}" ]] || return 1
  printf '%s\n' "$prev"
}

trim_overlap_with_previous() {
  local in_file="$1"
  local out_file="$2"
  local prev_raw prev_decoded prev_tmp
  local keep_overlap="${KEEP_OVERLAP:-0}"

  [[ "$keep_overlap" -eq 0 ]] || return 0

  if ! prev_raw="$(find_previous_log_in_series "$in_file")"; then
    return 0
  fi

  prev_decoded="$(derive_output_path "$prev_raw")"
  prev_tmp=""
  if [[ ! -f "$prev_decoded" ]]; then
    prev_tmp="$(/usr/bin/mktemp)"
    decode_raw_to_file "$prev_raw" "$prev_tmp" > /dev/null
    prev_decoded="$prev_tmp"
  fi

  LOGLM_DECODE_PREV_PATH="$prev_decoded" \
  LOGLM_DECODE_MIN_OVERLAP_LINES="${LOGLM_DECODE_MIN_OVERLAP_LINES:-20}" \
  LOGLM_DECODE_MIN_OVERLAP_CHARS="${LOGLM_DECODE_MIN_OVERLAP_CHARS:-400}" \
  perl -0pi -e '
use strict;
use warnings;

my $prev_path = $ENV{LOGLM_DECODE_PREV_PATH} // q{};
my $min_lines = $ENV{LOGLM_DECODE_MIN_OVERLAP_LINES} // 20;
my $min_chars = $ENV{LOGLM_DECODE_MIN_OVERLAP_CHARS} // 400;

open my $pfh, "<:raw", $prev_path or die "open prev: $!";
local $/;
my $prev = <$pfh>;
close $pfh;
my $curr = $_;

my @prev = split /\n/, $prev, -1;
my @curr = split /\n/, $curr, -1;

pop @prev while @prev && $prev[-1] eq q{};
pop @curr while @curr && $curr[-1] eq q{};

exit 0 if !@prev || !@curr;

my $body_start = 0;
for my $i (0 .. $#curr) {
  next unless $curr[$i] =~ /^===== loglm start /;
  $body_start = $i + 1;
  $body_start++ while $body_start < @curr && $curr[$body_start] eq q{};
  last;
}

my $best = 0;
my $best_chars = 0;
my $best_offset = -1;
my $anchor = $min_lines;
$anchor = @prev if $anchor > @prev;

my %candidates = ();
if ($anchor > 0) {
  my %prev_pos = ();
  for my $start (0 .. $#prev - $anchor + 1) {
    my $needle = join("\n", @prev[$start .. $start + $anchor - 1]);
    $prev_pos{$needle} = $start unless exists $prev_pos{$needle};
  }
  for my $offset ($body_start .. $#curr) {
    my $remaining = @curr - $offset;
    next if $remaining < $anchor;
    my $slice = join("\n", @curr[$offset .. $offset + $anchor - 1]);
    if (exists $prev_pos{$slice}) {
      $candidates{$offset} = $prev_pos{$slice};
    }
  }
}

for my $offset (sort { $a <=> $b } keys %candidates) {
  my $prev_start = $candidates{$offset};
  my $remaining = @curr - $offset;
  my $prev_remaining = @prev - $prev_start;
  my $max = $prev_remaining < $remaining ? $prev_remaining : $remaining;
  my $k = $anchor;
  while ($k < $max && $prev[$prev_start + $k] eq $curr[$offset + $k]) {
    $k++;
  }
  my $chars = 0;
  for my $i (0 .. $k - 1) {
    $chars += length($curr[$offset + $i]) + 1;
  }
  if ($k > $best || ($k == $best && $chars > $best_chars)) {
    $best = $k;
    $best_chars = $chars;
    $best_offset = $offset;
  }
}

if ($best >= $min_lines && $best_chars >= $min_chars) {
  my @kept = ();
  if ($body_start > 0) {
    @kept = @curr[0 .. $body_start - 1];
  }
  my @rest = ();
  if ($best_offset + $best <= $#curr) {
    @rest = @curr[$best_offset + $best .. $#curr];
  }
  while (@rest && $rest[0] !~ /^(?:\s*вЂє\s|\s*вЂў\s|===== loglm start )/) {
    shift @rest;
  }
  while (@rest && $rest[0] eq q{}) {
    shift @rest;
  }
  @curr = (@kept, @rest);
  $_ = join("\n", @curr);
  $_ .= "\n" if length($_);
}
' "$out_file"

  rm -f "$prev_tmp"
}

decode_one() {
  local in_file="$1"
  local out_file="$2"

  decode_raw_to_file "$in_file" "$out_file"
  trim_overlap_with_previous "$in_file" "$out_file"
}

output_path=""
KEEP_OVERLAP=0
inputs=()
while (($# > 0)); do
  case "$1" in
    -o|--output)
      if (($# < 2)); then
        echo "error: missing value for $1" >&2
        exit 2
      fi
      output_path="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --keep-overlap)
      KEEP_OVERLAP=1
      shift
      ;;
    --)
      shift
      while (($# > 0)); do
        inputs+=("$1")
        shift
      done
      ;;
    -*)
      echo "error: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      inputs+=("$1")
      shift
      ;;
  esac
done

if ((${#inputs[@]} == 0)); then
  echo "error: at least one input file is required." >&2
  usage >&2
  exit 2
fi

filtered_inputs=()
for in_file in "${inputs[@]}"; do
  if [[ "$in_file" == *.decoded.txt ]]; then
    continue
  fi
  filtered_inputs+=("$in_file")
done

if ((${#filtered_inputs[@]} == 0)); then
  echo "error: all input files were skipped (*.decoded.txt)." >&2
  exit 2
fi

inputs=("${filtered_inputs[@]}")

if [[ -n "$output_path" && ${#inputs[@]} -ne 1 ]]; then
  echo "error: --output can be used only with a single input file." >&2
  exit 2
fi

for in_file in "${inputs[@]}"; do
  if [[ ! -f "$in_file" ]]; then
    echo "input file not found: $in_file" >&2
    exit 1
  fi
done

if [[ -n "$output_path" ]]; then
  if [[ "${inputs[0]}" == "$output_path" ]]; then
    echo "error: input and output must be different files." >&2
    exit 2
  fi
  decode_one "${inputs[0]}" "$output_path"
  exit 0
fi

for in_file in "${inputs[@]}"; do
  out_file="$(derive_output_path "$in_file")"
  if [[ "$in_file" == "$out_file" ]]; then
    echo "error: input and output must be different files: $in_file" >&2
    exit 2
  fi
  decode_one "$in_file" "$out_file"
done
