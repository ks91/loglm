  local in_file="$1"
  local out_file="$2"

  decode_raw_to_file "$in_file" "$out_file"
  trim_overlap_with_previous "$in_file" "$out_file"
}

list_pii_candidates() {
  local in_file="$1"
  perl -CS -ne '
use strict;
use warnings;
use Encode qw(decode FB_DEFAULT);

binmode(STDOUT, ":encoding(UTF-8)");

my %count;
my %reason;
my %first_line_no;
my %first_line_text;

sub add_candidate {
  my ($value, $why, $line_no, $line_text) = @_;
  return if !defined($value) || $value eq q{};
  $count{$value}++;
  $reason{$value} = $why if !exists $reason{$value};
  $first_line_no{$value} = $line_no if !exists $first_line_no{$value};
  $first_line_text{$value} = $line_text if !exists $first_line_text{$value};
}

my $line = decode("UTF-8", $_, FB_DEFAULT);
while ($line =~ /([A-Za-z0-9._%+-]+\@[A-Za-z0-9.-]+\.[A-Za-z]{2,})/g) {
  add_candidate($1, "email", $., $line);
}
while ($line =~ /((?:\+?\d[\d .()]*[- ][\d .()-]*\d)|(?:\+?\d(?:[\d .()]*\d){9,}))/g) {
  my $candidate = $1;
  my $digits = ($candidate =~ tr/0-9//);
  next if $candidate =~ /^\d{4}-\d{2}-\d{2}$/;
  next if $candidate =~ /^\d{4}\/\d{2}\/\d{2}$/;
  next if $candidate =~ /^\d{4}-\d{2}-\d{2}[ T]\d{1,2}(?::\d{2}(?::\d{2})?)?$/;
  next if $candidate =~ /^\d{4}\/\d{2}\/\d{2}[ T]\d{1,2}(?::\d{2}(?::\d{2})?)?$/;
  next if $candidate =~ /^\d{8}-\d{6}$/;
  next if $candidate =~ /^\d{8}-\d{4}$/;
  next if $digits < 10;
  add_candidate($candidate, "phone", $., $line);
}
while ($line =~ m{((?:/Users/[^/\s]+|/home/[^/\s]+|/Volumes/[^/\s]+/[^/\s]+))}g) {
  add_candidate($1, "user_path", $., $line);
}
while ($line =~ /Welcome back ([A-Za-z][A-Za-z .'\''-]{1,40})!/g) {
  add_candidate($1, "greeting_name", $., $line);
}

END {
  for my $value (sort {
         $reason{$a} cmp $reason{$b}
      || $count{$b} <=> $count{$a}
      || length($b) <=> length($a)
      || $a cmp $b
    } keys %count) {
    chomp(my $line_text = $first_line_text{$value});
    print join("\t", $reason{$value}, $count{$value}, $value, $first_line_no{$value}, $line_text), "\n";
  }
}
' "$in_file"
}

replace_literal_in_file() {
  local file="$1"
  local needle="$2"
  local replacement="$3"
  NEEDLE="$needle" REPLACEMENT="$replacement" perl -0pi -e '
use strict;
use warnings;

my $needle = $ENV{NEEDLE} // q{};
my $replacement = $ENV{REPLACEMENT} // q{};
my $quoted = quotemeta($needle);
s/$quoted/$replacement/g;
' "$file"
}

list_grouped_pii_candidates() {
  local out_file="$1"
  local pii_list_file="$2"
  [[ -f "$pii_list_file" ]] || {
    echo "error: pii list file not found: $pii_list_file" >&2
    exit 1
  }

  OUT_FILE="$out_file" PII_LIST_FILE="$pii_list_file" perl -CS -e '
use strict;
use warnings;
use Encode qw(decode FB_DEFAULT);

binmode(STDOUT, ":encoding(UTF-8)");

my $out_file = $ENV{OUT_FILE} // q{};
my $pii_list_file = $ENV{PII_LIST_FILE} // q{};

open my $fh, "<:raw", $out_file or die "open out_file: $!";
my @lines = map { decode("UTF-8", $_, FB_DEFAULT) } <$fh>;
close $fh;

open my $pfh, "<:raw", $pii_list_file or die "open pii_list_file: $!";
my @raw_groups;
my @current;
while (my $raw = <$pfh>) {
  my $line = decode("UTF-8", $raw, FB_DEFAULT);
  chomp $line;
  $line =~ s/\r$//;
  if ($line =~ /^\s*#/) {
    next;
  }
  if ($line =~ /^\s*$/) {
    if (@current) {
      push @raw_groups, [@current];
      @current = ();
    }
    next;
  }
  push @current, $line;
}
push @raw_groups, [@current] if @current;
close $pfh;

my %seen_value;
for my $gidx (0 .. $#raw_groups) {
  my @unique = grep { !$seen_value{$_}++ } @{ $raw_groups[$gidx] };
  @unique = sort { length($b) <=> length($a) || $a cmp $b } @unique;
  my $token = sprintf("***%d*", $gidx + 1);
  my ($first_line_no, $first_line_text, $hits) = (undef, undef, 0);
  for my $candidate (@unique) {
    for my $i (0 .. $#lines) {
      if (index($lines[$i], $candidate) >= 0) {
        $hits++;
        if (!defined $first_line_no) {
          $first_line_no = $i + 1;
          (my $copy = $lines[$i]) =~ s/\r?\n$//;
          $first_line_text = $copy;
        }
      }
    }
  }
  next if !$hits;
  my $joined = join("\x1f", @unique);
  print join("\t", "pii_group", $hits, $token, ($first_line_no // q{}), ($first_line_text // q{}), $joined), "\n";
}
' 
}

replace_group_in_file() {
  local file="$1"
  local replacement="$2"
  shift 2
  local values=("$@")
  local value
  for value in "${values[@]}"; do
    replace_literal_in_file "$file" "$value" "$replacement"
  done
}

review_pii_candidates() {
  local out_file="$1"
  local pii_list_file="$2"
  local replace_all="${3:-0}"
  local line reason count replacement line_no line_text group_values answer total index
  local -a values
  local -a candidates

  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    candidates+=("$line")
  done < <(list_grouped_pii_candidates "$out_file" "$pii_list_file")

  total="${#candidates[@]}"
  if ((total == 0)); then
    echo "pii-review: no candidates found in $out_file"
    return 0
  fi

  echo "pii-review: $total candidate(s) found in $out_file"
  index=0
  for line in "${candidates[@]}"; do
    index=$((index + 1))
    IFS=$'\t' read -r reason count replacement line_no line_text group_values <<< "$line"
    IFS=$'\x1f' read -r -a values <<< "$group_values"
    printf '[%d/%d] %s (%s hit%s): %s\n' \
      "$index" "$total" "$reason" "$count" \
      "$([[ "$count" == "1" ]] && printf '' || printf 's')" \
      "$replacement"
    if [[ -n "${line_no:-}" && -n "${line_text:-}" ]]; then
      printf '        line %s: %s\n' "$line_no" "$line_text"
    fi
    printf '        aliases: %s\n' "$(IFS=', '; printf '%s' "${values[*]}")"
    if [[ "$replace_all" -eq 1 ]]; then
      replace_group_in_file "$out_file" "$replacement" "${values[@]}"
      continue
    fi
    while true; do
      printf 'Replace with "%s"? [y/N/q] ' "$replacement" >&2
      IFS= read -r answer || answer="q"
      case "$answer" in
        y|Y|yes|YES)
          replace_group_in_file "$out_file" "$replacement" "${values[@]}"
          break
          ;;
        q|Q|quit|QUIT)
          echo "pii-review: stopped after $((index - 1)) reviewed candidate(s)"
          return 0
          ;;
        ""|n|N|no|NO)
          break
          ;;
        *)
          echo "Please answer y, n, or q." >&2
          ;;
      esac
    done
  done
}

output_path=""
KEEP_OVERLAP=0
REVIEW_PII=0
REPLACE_ALL=0
inputs=()
while (($# > 0)); do
  case "$1" in
    -o|--output)
      if (($# < 2)); then
        echo "error: missing value for $1" >&2
        exit 2
      fi
      output_path="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --keep-overlap)
      KEEP_OVERLAP=1
      shift
      ;;
    --review-pii)
      REVIEW_PII=1
      shift
      ;;
    --replace-all)
      REPLACE_ALL=1
      shift
      ;;
    --)
      shift
      while (($# > 0)); do
        inputs+=("$1")
        shift
      done
      ;;
    -*)
      echo "error: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      inputs+=("$1")
      shift
      ;;
  esac
done

if ((${#inputs[@]} == 0)); then
  echo "error: at least one input file is required." >&2
  usage >&2
  exit 2
fi

filtered_inputs=()
for in_file in "${inputs[@]}"; do
  if [[ "$in_file" == *.decoded.txt && "$REVIEW_PII" -eq 0 ]]; then
    continue
  fi
  filtered_inputs+=("$in_file")
done

if ((${#filtered_inputs[@]} == 0)); then
  echo "error: all input files were skipped (*.decoded.txt)." >&2
  exit 2
fi

inputs=("${filtered_inputs[@]}")

PII_LIST_INPUT=""
if [[ "$REVIEW_PII" -eq 1 ]]; then
  if ((${#inputs[@]} < 2)); then
    echo "error: --review-pii requires a pii-candidates.txt file followed by at least one input log." >&2
    exit 2
  fi
  PII_LIST_INPUT="${inputs[0]}"
  inputs=("${inputs[@]:1}")
fi

if [[ -n "$output_path" && ${#inputs[@]} -ne 1 ]]; then
  echo "error: --output can be used only with a single input file." >&2
  exit 2
fi

for in_file in "${inputs[@]}"; do
  if [[ ! -f "$in_file" ]]; then
    echo "input file not found: $in_file" >&2
    exit 1
  fi
done

  if [[ -n "$output_path" ]]; then
    if [[ "${inputs[0]}" == "$output_path" ]]; then
      echo "error: input and output must be different files." >&2
      exit 2
    fi
    if is_decoded_input "${inputs[0]}" || is_redacted_input "${inputs[0]}"; then
      cp "${inputs[0]}" "$output_path"
    else
      decode_one "${inputs[0]}" "$output_path"
    fi
    if [[ "$REVIEW_PII" -eq 1 ]]; then
      review_pii_candidates "$output_path" "$PII_LIST_INPUT" "$REPLACE_ALL"
    fi
  exit 0
fi

for in_file in "${inputs[@]}"; do
  if [[ "$REVIEW_PII" -eq 1 ]]; then
    out_file="$(derive_redacted_output_path "$in_file")"
  else
    out_file="$(derive_output_path "$in_file")"
  fi
  if [[ "$in_file" == "$out_file" ]]; then
    if [[ "$REVIEW_PII" -eq 1 ]] && is_redacted_input "$in_file"; then
      review_pii_candidates "$out_file" "$DEFAULT_REPLACEMENT"
      continue
    fi
    echo "error: input and output must be different files: $in_file" >&2
    exit 2
  fi
  if is_decoded_input "$in_file" || is_redacted_input "$in_file"; then
    cp "$in_file" "$out_file"
  else
    decode_one "$in_file" "$out_file"
  fi
  if [[ "$REVIEW_PII" -eq 1 ]]; then
    review_pii_candidates "$out_file" "$PII_LIST_INPUT" "$REPLACE_ALL"
  fi
done
