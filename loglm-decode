#!/usr/bin/env bash
set -euo pipefail

usage() {
  local cmd
  cmd="$(basename "$0")"
  cat <<'EOF'
Usage:
EOF
  cat <<EOF
  $cmd [options] <input_file>...

Options:
  -o, --output <file>  Output file path (single input only)
  --keep-overlap       Keep overlapping context instead of trimming it
  --review-pii         Review and redact using a grouped PII candidate list
  --replace-all        Replace all matched candidates without prompting
  -h, --help           Show this help

Behavior:
  - Positional arguments are always treated as input files.
  - Without -o, each input is written to "<input_basename>.decoded.txt".
    Example: logs/codex-log-20260217.txt -> logs/codex-log-20260217.decoded.txt
  - By default, overlapping leading context shared with the previous log
    in the same series is trimmed from the current decoded output.
  - With --review-pii, the first positional argument is a grouped
    pii-candidates.txt file and the remaining positional arguments are logs.
  - Empty lines in pii-candidates.txt separate person/entity groups.
  - Each group is replaced with a numbered token: ***1*, ***2*, ...
  - --replace-all applies the numbered replacement to every matched group
    without prompts.
EOF
}

derive_output_path() {
  local in_file="$1"
  local dir base stem
  dir="$(dirname "$in_file")"
  base="$(basename "$in_file")"
  stem="${base%.*}"
  if [[ "$stem" == "$base" ]]; then
    printf '%s/%s.decoded.txt\n' "$dir" "$base"
  else
    printf '%s/%s.decoded.txt\n' "$dir" "$stem"
  fi
}

derive_redacted_output_path() {
  local in_file="$1"
  local dir base stem
  dir="$(dirname "$in_file")"
  base="$(basename "$in_file")"
  if [[ "$base" == *.redacted.txt ]]; then
    printf '%s/%s\n' "$dir" "$base"
    return 0
  fi
  stem="${base%.decoded.txt}"
  if [[ "$stem" == "$base" ]]; then
    stem="${base%.redacted.txt}"
  fi
  if [[ "$stem" == "$base" ]]; then
    stem="${base%.*}"
  fi
  printf '%s/%s.redacted.txt\n' "$dir" "$stem"
}

is_decoded_input() {
  local in_file="$1"
  [[ "$in_file" == *.decoded.txt ]]
}

is_redacted_input() {
  local in_file="$1"
  [[ "$in_file" == *.redacted.txt ]]
}

decode_raw_to_file() {
  local in_file="$1"
  local out_file="$2"
  local tmp_file
  local profile base
  tmp_file="$(/usr/bin/mktemp)"
  trap 'rm -f "$tmp_file"' RETURN

  profile="${LOGLM_DECODE_PROFILE:-auto}"
  if [[ "$profile" == "auto" ]]; then
    base="$(basename "$in_file" | tr '[:upper:]' '[:lower:]')"
    if [[ "$base" == *claude* ]]; then
      profile="claude"
    elif [[ "$base" == *gemini* ]]; then
      profile="gemini"
    elif [[ "$base" == *codex* ]]; then
      profile="codex"
    else
      profile="default"
    fi
  fi

  LOGLM_DECODE_PROFILE="$profile" perl -e '
use strict;
use warnings;
use Encode qw(decode encode FB_DEFAULT);

binmode(STDIN);
binmode(STDOUT);

my $NORMAL = 0;
my $ESC = 1;
my $CSI = 2;
my $OSC = 3;
my $OSC_ESC = 4;
my $DCS = 5;
my $DCS_ESC = 6;

my $state = $NORMAL;
my $out = q{};
my $c;
my $pending_cr = 0;
my $csi_param = q{};
my $profile = $ENV{LOGLM_DECODE_PROFILE} // q{};
my $is_claude = ($profile eq "claude") ? 1 : 0;
my $is_gemini = ($profile eq "gemini") ? 1 : 0;

while (read(STDIN, $c, 1)) {
  my $b = ord($c);

  if ($state == $NORMAL) {
    if ($pending_cr) {
      if ($b == 0x0A) {
        # CR+LF (including CR+CR+LF): single newline.
        $out .= "\n";
        $pending_cr = 0;
        next;
      } elsif ($b == 0x0D) {
        # Consecutive CRs (e.g. Claude Code uses \r\r\n): ignore extra CR.
        next;
      } else {
        # Lone CR: move to start of current line (overwrite semantics).
        my $last_nl = rindex($out, "\n");
        if ($last_nl >= 0) {
          substr($out, $last_nl + 1) = q{};
        } else {
          $out = q{};
        }
        $pending_cr = 0;
        # Fall through to process $b normally.
      }
    }

    if ($b == 0x1B) { # ESC
      $state = $ESC;
    } elsif ($b == 0x08) { # BS
      substr($out, -1, 1, q{}) if length($out) > 0;
    } elsif ($b == 0x0D) { # CR
      # Defer until next byte so CRLF does not become double newline.
      $pending_cr = 1;
    } elsif ($b == 0x0A || $b == 0x09) { # LF/TAB
      $out .= $c;
    } elsif ($b < 0x20 || $b == 0x7F) {
      # drop other C0 controls and DEL
    } else {
      $out .= $c;
    }
    next;
  }

  if ($state == $ESC) {
    if ($b == ord("[")) {
      $state = $CSI;
      $csi_param = q{};
    } elsif ($b == ord("]")) {
      $state = $OSC;
    } elsif ($b == ord("P")) {
      $state = $DCS;
    } else {
      # single escape sequence
      $state = $NORMAL;
    }
    next;
  }

  if ($state == $CSI) {
    if ($b >= 0x40 && $b <= 0x7E) {
      # CSI final byte.
      if ($b == ord("C")) {
        # Cursor Forward: many TUIs (e.g. Claude Code/Ink) use ESC[nC
        # instead of literal spaces for inter-word/column spacing.
        my $n = ($csi_param =~ /^(\d+)$/) ? int($csi_param) : 1;
        $out .= " " x $n if $n > 0;
      }
      $state = $NORMAL;
    } else {
      $csi_param .= $c;
    }
    next;
  }

  if ($state == $OSC) {
    if ($b == 0x07) { # BEL
      $state = $NORMAL;
    } elsif ($b == 0x1B) {
      $state = $OSC_ESC;
    }
    next;
  }

  if ($state == $OSC_ESC) {
    if ($b == ord("\\")) {
      $state = $NORMAL;
    } else {
      $state = $OSC;
    }
    next;
  }

  if ($state == $DCS) {
    if ($b == 0x1B) {
      $state = $DCS_ESC;
    }
    next;
  }

  if ($state == $DCS_ESC) {
    if ($b == ord("\\")) {
      $state = $NORMAL;
    } else {
      $state = $DCS;
    }
    next;
  }
}

if ($pending_cr) {
  $out .= "\n";
}

# Trim trailing whitespace from each line (leftover from ESC[nC padding).
$out =~ s/[ \t]+\n/\n/g;
$out =~ s/[ \t]+\z//;

my $text = decode("UTF-8", $out, FB_DEFAULT);
my @lines = split /\n/, $text, -1;
my @merged = ();
if ($is_claude) {
  # Merge "staircase" input echoes common in Claude TUI redraws.
  for (my $i = 0; $i < @lines; ) {
    my @tokens = ();
    my @indents = ();
    my $j = $i;
    my $consumed_any = 0;

    while ($j < @lines) {
      my $line = $lines[$j];
      if ($line eq q{}) {
        $j++;
        next if @tokens > 0;
        last;
      }

      last unless $line =~ /^(\s*)(\S.*?)\s*$/;
      my $indent = length($1);
      my $token = $2;
      last if $token =~ /\s/;
      last if length($token) > 24;
      last if @indents && $indent < $indents[-1];

      push @indents, $indent;
      push @tokens, $token;
      $consumed_any = 1;
      $j++;
      last if @tokens >= 300;
    }

    if (@tokens >= 4) {
      my $inc = 0;
      for (my $k = 1; $k < @indents; $k++) {
        $inc++ if $indents[$k] > $indents[$k - 1];
      }
      if ($inc >= int(@tokens * 0.6)) {
        push @merged, join(q{}, @tokens);
        $i = $j;
        next;
      }
    }

    if ($consumed_any) {
      push @merged, $lines[$i];
      $i++;
    } else {
      push @merged, $lines[$i];
      $i++;
    }
  }
} elsif ($is_gemini) {
  my @normalized = ();
  my $pending_prompt;
  my $last_emitted_prompt;
  my $in_notice_block = 0;
  my $in_slash_menu = 0;

  for my $raw (@lines) {
    my $line = $raw;

    # Drop box borders produced by Gemini TUI redraws.
    next if $line =~ /^\s*[\p{Block=Box_Drawing}]+\s*$/u;

    # Unwrap boxed lines: "│ ... │" -> "..."
    if ($line =~ /^\s*\p{Block=Box_Drawing}(.*)\p{Block=Box_Drawing}\s*$/u) {
      $line = $1;
      $line =~ s/^\s+//;
      $line =~ s/\s+$//;
    } else {
      $line =~ s/\s+$//;
    }

    if ($in_notice_block) {
      $in_notice_block = 0 if $line =~ /^\s*Read more: https:\/\/goo\.gle\/geminicli-updates\s*$/;
      next;
    }

    if ($line =~ /^\s*We.re making changes to Gemini CLI that may impact your workflow\.\s*$/) {
      $in_notice_block = 1;
      next;
    }

    if ($in_slash_menu) {
      if (
        $line =~ /^\s*▼\s*$/ ||
        $line =~ /^\s*\(\d+\/\d+\)\s*$/ ||
        $line =~ /^\s*[a-z][a-z0-9-]*(?:\s{2,}|\t+).+/i
      ) {
        next;
      }
      $in_slash_menu = 0;
    }

    # Drop frequent transient UI lines.
    if (
      $line eq q{} ||
      $line =~ /Waiting for auth/i ||
      $line =~ /Gemini CLI update available!/ ||
      $line =~ /Installed via Homebrew\./ ||
      $line =~ /^loglm-gemini$/ ||
      $line =~ /^no sandbox \(see \/docs\)$/ ||
      $line =~ /no sandbox \(see \/docs\)/ ||
      $line =~ /^gemini-[[:alnum:]._-]+ \(\d+% context left\)$/ ||
      $line =~ /^\s*(?:[\x{2580}-\x{259F}\x{2800}-\x{28FF}]+\s+)?Gemini CLI v[0-9.]+\s*$/u ||
      $line =~ m{^\s*(?:[\x{2580}-\x{259F}\x{2800}-\x{28FF}]+\s+)?Signed in with Google: .* /auth\s*$}u ||
      $line =~ m{^\s*(?:[\x{2580}-\x{259F}\x{2800}-\x{28FF}]+\s+)?Plan: .* /upgrade\s*$}u ||
      $line =~ m{^\s*workspace \(/directory\)\s+sandbox\s+/model\s*$} ||
      $line =~ m{^\s*~/.*\s+no sandbox\s+Auto \(Gemini 3\)\s*$} ||
      $line =~ /^\s*Shift\+Tab to accept edits\s*$/i ||
      $line =~ /^\s*\? for shortcuts\s*$/i ||
      $line =~ /^\s*▼\s*$/ ||
      $line =~ /^\s*\(\d+\/\d+\)\s*$/ ||
      ($line =~ /^\s*\X\s*$/u && $line !~ /[[:alnum:]]/) ||
      $line =~ m{^\s*>\s*Type your message or \@path/to/file\s*$} ||
      $line =~ /^\s*What.s Changing: / ||
      $line =~ /^\s*How it affects you: / ||
      $line =~ /^\s*Read more: https:\/\/goo\.gle\/geminicli-updates\s*$/ ||
      $line =~ /^[\x{2800}-\x{28FF}]\s+/u ||
      $line =~ /^\s*[\x{2800}-\x{28FF}]?\s*(?:Thinking\.\.\.|[A-Z][A-Za-z]+(?: [A-Z][A-Za-z]+){0,6})\s+\(esc to cancel,\s*\d+s\)(?:\s+.*)?$/u
    ) {
      next;
    }

    # Merge staircase-style prompt redraws into one line.
    if ($line =~ /^\s*>\s*(.*)$/) {
      my $p = $1;
      $p =~ s/^\s+//;
      $p =~ s/\s+$//;
      next if $p eq q{};
      if (defined $pending_prompt && $pending_prompt =~ m{^/\S+} && $p =~ m{^/\S+}) {
        $pending_prompt = $p;
        next;
      }
      if (!defined $pending_prompt) {
        $pending_prompt = $p;
        next;
      }
      if ($p =~ /^\Q$pending_prompt\E/ || $pending_prompt =~ /^\Q$p\E/) {
        # Continue tracking while user edits (both extension and backspace).
        $pending_prompt = $p;
        next;
      }
      if (
        $pending_prompt ne q{} &&
        (length($pending_prompt) >= 4 || $pending_prompt =~ m{^/}) &&
        (!defined $last_emitted_prompt || $last_emitted_prompt ne $pending_prompt)
      ) {
        push @normalized, "> $pending_prompt";
        $last_emitted_prompt = $pending_prompt;
      }
      $pending_prompt = $p;
      next;
    }

    if (defined $pending_prompt) {
      next if $line =~ m{^\s*workspace \(/directory\)\s+sandbox\s+/model\s*$};
      if (
        $pending_prompt =~ m{^/\S+} &&
        (
          $line =~ /^\s*▼\s*$/ ||
          $line =~ /^\s*\(\d+\/\d+\)\s*$/ ||
          $line =~ /^\s*[a-z][a-z0-9-]*(?:\s{2,}|\t+).+/i
        )
      ) {
        $in_slash_menu = 1;
        undef $pending_prompt;
        next;
      }
      if ($line eq $pending_prompt) {
        next;
      }
      if (
        $pending_prompt ne q{} &&
        (length($pending_prompt) >= 4 || $pending_prompt =~ m{^/}) &&
        (!defined $last_emitted_prompt || $last_emitted_prompt ne $pending_prompt)
      ) {
        push @normalized, "> $pending_prompt";
        $last_emitted_prompt = $pending_prompt;
      }
      undef $pending_prompt;
    }
    if (defined $last_emitted_prompt && $line eq $last_emitted_prompt) {
      next;
    }

    push @normalized, $line;
  }

  if (defined $pending_prompt) {
    if (
      $pending_prompt ne q{} &&
      (length($pending_prompt) >= 4 || $pending_prompt =~ m{^/}) &&
      (!defined $last_emitted_prompt || $last_emitted_prompt ne $pending_prompt)
    ) {
      push @normalized, "> $pending_prompt";
    }
  }

  @merged = @normalized;
} else {
  @merged = @lines;
}

# Collapse noisy consecutive duplicates and repeated blank lines.
my @dedup = ();
my $prev_cmp = undef;
my $blank_run = 0;
for my $line (@merged) {
  my $line_out = $line;
  if ($line eq q{}) {
    next if $is_claude && defined $prev_cmp && ($prev_cmp eq "(thinking)" || $prev_cmp eq "(status)" || $prev_cmp eq "(spinner)");
    $blank_run++;
    next if $blank_run > 1;
  } else {
    $blank_run = 0;
  }

  my $cmp = $line;
  if ($is_claude) {
    $cmp =~ s/^\s+//;
    $cmp =~ s/\s+$//;
    if ($cmp =~ /\(thinking\)/) {
      $cmp = "(thinking)";
      $line_out = "(thinking)";
    }
    if (
      $cmp ne "(thinking)" &&
      length($cmp) <= 80 &&
      $cmp =~ /ing/i &&
      $cmp !~ m{[/:\\]}
    ) {
      $cmp = "(status)";
      $line_out = "(status)";
    }
    $cmp = "(spinner)" if $cmp =~ /^[·✢✳✶✻✽⏺]+$/;
    if (
      defined $prev_cmp &&
      $prev_cmp eq "(status)" &&
      $cmp =~ /^[[:alpha:][:space:]…-]{1,24}$/
    ) {
      $cmp = "(status)";
      $line_out = "(status)";
    }
    if (
      defined $prev_cmp &&
      ($prev_cmp eq "(status)" || $prev_cmp eq "(spinner)" || $prev_cmp eq "(thinking)") &&
      $cmp =~ /[[:alpha:]]/ &&
      $cmp =~ /^[·✢✳✶✻✽⏺[:space:][:alnum:]…-]{1,24}$/
    ) {
      $cmp = "(status)";
      $line_out = "(status)";
    }
    if (
      $cmp =~ /[[:alpha:]][[:space:]]+[[:alpha:]]/ &&
      length($cmp) <= 24 &&
      $cmp =~ /^[·✢✳✶✻✽⏺[:space:][:alnum:]…-]+$/
    ) {
      $cmp = "(status)";
      $line_out = "(status)";
    }
    if (
      length($cmp) <= 28 &&
      ($cmp =~ /[↑↓…]/ || $cmp =~ /[·✢✳✶✻✽⏺]/) &&
      $cmp =~ /^[·✢✳✶✻✽⏺↑↓[:space:][:alnum:]…-]+$/
    ) {
      $cmp = "(status)";
      $line_out = "(status)";
    }
  } elsif ($is_gemini) {
    $cmp =~ s/^\s+//;
    $cmp =~ s/\s+$//;
    # Startup banner art is mostly decorative and very noisy.
    if ($cmp =~ /^[[:space:]\p{Block=Block_Elements}]+$/u) {
      next;
    }
  }

  if (
    $is_claude &&
    $cmp eq "(spinner)" &&
    defined $prev_cmp &&
    ($prev_cmp eq "(spinner)" || $prev_cmp eq "(thinking)" || $prev_cmp eq "(status)")
  ) {
    next;
  }
  next if defined $prev_cmp && $cmp eq $prev_cmp && $cmp ne q{};
  push @dedup, $line_out;
  $prev_cmp = $cmp;
}
$out = join("\n", @dedup);

# Collapse 3+ consecutive newlines to 2 (at most one blank line).
$out =~ s/\n{3,}/\n\n/g;

print STDOUT encode("UTF-8", $out);
' < "$in_file" > "$tmp_file"

  mv "$tmp_file" "$out_file"
  trap - RETURN

  echo "decoded: $in_file -> $out_file"
}

find_previous_log_in_series() {
  local in_file="$1"
  local dir base prefix prev candidate candidate_base
  dir="$(dirname "$in_file")"
  base="$(basename "$in_file")"

  if [[ ! "$base" =~ ^(loglm-[^-]+-log-).+\.txt$ ]]; then
    return 1
  fi
  prefix="${BASH_REMATCH[1]}"

  while IFS= read -r candidate; do
    candidate_base="$(basename "$candidate")"
    [[ "$candidate_base" == *.decoded.txt ]] && continue
    [[ "$candidate_base" == "$base" ]] && continue
    if [[ "$candidate_base" < "$base" ]]; then
      prev="$candidate"
    fi
  done < <(find "$dir" -maxdepth 1 -type f -name "${prefix}*.txt" | LC_ALL=C sort)

  [[ -n "${prev:-}" ]] || return 1
  printf '%s\n' "$prev"
}

trim_overlap_with_previous() {
  local in_file="$1"
  local out_file="$2"
  local prev_raw prev_decoded prev_tmp profile base
  local keep_overlap="${KEEP_OVERLAP:-0}"

  [[ "$keep_overlap" -eq 0 ]] || return 0

  if ! prev_raw="$(find_previous_log_in_series "$in_file")"; then
    return 0
  fi

  profile="default"
  base="$(basename "$in_file" | tr '[:upper:]' '[:lower:]')"
  if [[ "$base" == *claude* ]]; then
    profile="claude"
  elif [[ "$base" == *gemini* ]]; then
    profile="gemini"
  elif [[ "$base" == *codex* ]]; then
    profile="codex"
  fi

  prev_tmp="$(/usr/bin/mktemp)"
  decode_raw_to_file "$prev_raw" "$prev_tmp" > /dev/null
  prev_decoded="$prev_tmp"

  LOGLM_DECODE_PREV_PATH="$prev_decoded" \
  LOGLM_DECODE_OVERLAP_PROFILE="$profile" \
  LOGLM_DECODE_MIN_OVERLAP_LINES="${LOGLM_DECODE_MIN_OVERLAP_LINES:-20}" \
  LOGLM_DECODE_MIN_OVERLAP_CHARS="${LOGLM_DECODE_MIN_OVERLAP_CHARS:-400}" \
  perl -0pi -e '
use strict;
use warnings;

my $prev_path = $ENV{LOGLM_DECODE_PREV_PATH} // q{};
my $profile = $ENV{LOGLM_DECODE_OVERLAP_PROFILE} // q{};
my $min_lines = $ENV{LOGLM_DECODE_MIN_OVERLAP_LINES} // 20;
my $min_chars = $ENV{LOGLM_DECODE_MIN_OVERLAP_CHARS} // 400;

open my $pfh, "<:raw", $prev_path or die "open prev: $!";
local $/;
my $prev = <$pfh>;
close $pfh;
my $curr = $_;

my @prev = split /\n/, $prev, -1;
my @curr = split /\n/, $curr, -1;

pop @prev while @prev && $prev[-1] eq q{};
pop @curr while @curr && $curr[-1] eq q{};

exit 0 if !@prev || !@curr;

my $body_start = 0;
for my $i (0 .. $#curr) {
  next unless $curr[$i] =~ /^===== loglm start /;
  $body_start = $i + 1;
  $body_start++ while $body_start < @curr && $curr[$body_start] eq q{};
  last;
}

sub normalize_overlap_line {
  my ($line) = @_;
  $line //= q{};
  $line =~ s/^\s+//;
  $line =~ s/\s+$//;
  $line =~ s/\s+/ /g;
  return $line;
}

sub build_overlap_blocks {
  my ($lines_ref, $start_idx) = @_;
  my @lines = @{$lines_ref};
  my @blocks = ();
  my $i = $start_idx;

  while ($i <= $#lines) {
    while ($i <= $#lines && ($lines[$i] eq q{} || $lines[$i] =~ /^[─-]{10,}\s*$/)) {
      $i++;
    }
    last if $i > $#lines;

    my $start = $i;
    my @parts = ();
    my $head = q{};
    while ($i <= $#lines) {
      my $line = $lines[$i];
      last if $i > $start && $line =~ /^(?:\s*›\s|\s*•\s|\s*■\s|\s*❯\s|\s*⏺\s|===== loglm start )/;
      last if $line =~ /^[─-]{10,}\s*$/;
      last if $i > $start && $line eq q{};
      my $normalized = normalize_overlap_line($line);
      $head = $normalized if $head eq q{} && $normalized ne q{};
      push @parts, $normalized;
      $i++;
    }

    my $text = join q{ }, grep { $_ ne q{} } @parts;
    $text =~ s/\s+/ /g;
    $text =~ s/^\s+//;
    $text =~ s/\s+$//;
    next if $text eq q{};
    push @blocks, [$start, $i - 1, $text, $head];
  }

  return @blocks;
}

my $best = 0;
my $best_chars = 0;
my $best_offset = -1;
my $anchor = $min_lines;
$anchor = @prev if $anchor > @prev;

my %candidates = ();
if ($anchor > 0) {
  my %prev_pos = ();
  for my $start (0 .. $#prev - $anchor + 1) {
    my $needle = join("\n", @prev[$start .. $start + $anchor - 1]);
    $prev_pos{$needle} = $start unless exists $prev_pos{$needle};
  }
  for my $offset ($body_start .. $#curr) {
    my $remaining = @curr - $offset;
    next if $remaining < $anchor;
    my $slice = join("\n", @curr[$offset .. $offset + $anchor - 1]);
    if (exists $prev_pos{$slice}) {
      $candidates{$offset} = $prev_pos{$slice};
    }
  }
}

for my $offset (sort { $a <=> $b } keys %candidates) {
  my $prev_start = $candidates{$offset};
  my $remaining = @curr - $offset;
  my $prev_remaining = @prev - $prev_start;
  my $max = $prev_remaining < $remaining ? $prev_remaining : $remaining;
  my $k = $anchor;
  while ($k < $max && $prev[$prev_start + $k] eq $curr[$offset + $k]) {
    $k++;
  }
  my $chars = 0;
  for my $i (0 .. $k - 1) {
    $chars += length($curr[$offset + $i]) + 1;
  }
  if ($k > $best || ($k == $best && $chars > $best_chars)) {
    $best = $k;
    $best_chars = $chars;
    $best_offset = $offset;
  }
}

if ($profile eq "codex") {
  my @prev_blocks = build_overlap_blocks(\@prev, 0);
  my @curr_blocks = build_overlap_blocks(\@curr, $body_start);
  my %prev_pos = ();

  for my $idx (0 .. $#prev_blocks) {
    my $text = $prev_blocks[$idx]->[2];
    my $head = $prev_blocks[$idx]->[3];
    if ($text ne q{} && !exists $prev_pos{$text}) {
      $prev_pos{$text} = $idx;
    }
    next if $head eq q{};
    $prev_pos{$head} = $idx unless exists $prev_pos{$head};
  }

  if (@curr_blocks) {
    my $prefix_best_blocks = 0;
    my $prefix_best_chars = 0;
    my $prefix_best_end = -1;

    CANDIDATE:
    for my $start_prev (0 .. $#prev_blocks) {
      my $curr0_text = $curr_blocks[0]->[2];
      my $curr0_head = $curr_blocks[0]->[3];
      my $prev0_text = $prev_blocks[$start_prev]->[2];
      my $prev0_head = $prev_blocks[$start_prev]->[3];
      next unless (
        ($curr0_text ne q{} && $curr0_text eq $prev0_text) ||
        ($curr0_head ne q{} && $curr0_head eq $prev0_head)
      );

      my $pj = $start_prev;
      my $matched_blocks = 0;
      my $matched_chars = 0;
      my $last_matched_ci = -1;
      my $miss_streak = 0;

      for my $ci (0 .. $#curr_blocks) {
        my $found = -1;
        for my $probe ($pj .. $#prev_blocks) {
          my $curr_text = $curr_blocks[$ci]->[2];
          my $prev_text = $prev_blocks[$probe]->[2];
          my $curr_head = $curr_blocks[$ci]->[3];
          my $prev_head = $prev_blocks[$probe]->[3];
          if (
            ($curr_text ne q{} && $curr_text eq $prev_text) ||
            ($curr_head ne q{} && $curr_head eq $prev_head)
          ) {
            $found = $probe;
            last;
          }
        }

        if ($found >= 0) {
          $matched_blocks++;
          $matched_chars += length($curr_blocks[$ci]->[2]) + 1;
          $last_matched_ci = $ci;
          $pj = $found + 1;
          $miss_streak = 0;
        } else {
          $miss_streak++;
          last if $miss_streak >= 3 && $matched_blocks >= 3;
        }
      }

      next if $matched_blocks < 3;
      if (
        $matched_blocks > $prefix_best_blocks ||
        ($matched_blocks == $prefix_best_blocks && $matched_chars > $prefix_best_chars)
      ) {
        $prefix_best_blocks = $matched_blocks;
        $prefix_best_chars = $matched_chars;
        $prefix_best_end = $last_matched_ci;
      }
    }

    if ($prefix_best_end >= 0 && $prefix_best_chars >= $min_chars) {
      $best_offset = $curr_blocks[0]->[0];
      $best = $curr_blocks[$prefix_best_end]->[1] - $curr_blocks[0]->[0] + 1;
      $best_chars = $prefix_best_chars;
    }
  }

  my $best_block_count = 0;
  my $best_block_chars = 0;

  if ($best_offset < 0) {
    for my $curr_idx (0 .. $#curr_blocks) {
      my $first_text = $curr_blocks[$curr_idx]->[2];
      my $first_head = $curr_blocks[$curr_idx]->[3];
      my $first = exists $prev_pos{$first_text} ? $first_text : $first_head;
      next unless exists $prev_pos{$first};
      my $prev_idx = $prev_pos{$first};
      my $k = 0;
      my $chars = 0;
      while (
        $curr_idx + $k <= $#curr_blocks &&
        $prev_idx + $k <= $#prev_blocks
      ) {
        my $curr_text = $curr_blocks[$curr_idx + $k]->[2];
        my $prev_text = $prev_blocks[$prev_idx + $k]->[2];
        my $curr_head = $curr_blocks[$curr_idx + $k]->[3];
        my $prev_head = $prev_blocks[$prev_idx + $k]->[3];
        last unless (
          ($curr_text ne q{} && $curr_text eq $prev_text) ||
          ($curr_head ne q{} && $curr_head eq $prev_head)
        );
        $chars += length($curr_blocks[$curr_idx + $k]->[2]) + 1;
        $k++;
      }
      if ($k > $best_block_count || ($k == $best_block_count && $chars > $best_block_chars)) {
        $best_block_count = $k;
        $best_block_chars = $chars;
        $best_offset = $curr_blocks[$curr_idx]->[0];
        $best = $curr_blocks[$curr_idx + $k - 1]->[1] - $curr_blocks[$curr_idx]->[0] + 1;
        $best_chars = $chars;
      }
    }
  }
}

if ($best >= $min_lines && $best_chars >= $min_chars) {
  if ($profile eq "codex" && $best_offset == $body_start) {
    my $scan_limit = $body_start + 220;
    $scan_limit = $#curr if $scan_limit > $#curr;
    for my $i ($body_start .. $scan_limit) {
      if ($curr[$i] =~ /Context compacted\b/) {
        my $extended = $i - $best_offset + 1;
        if ($extended > $best) {
          $best = $extended;
        }
        last;
      }
    }
  }

  my @kept = ();
  if ($body_start > 0) {
    @kept = @curr[0 .. $body_start - 1];
  }
  my @rest = ();
  if ($best_offset + $best <= $#curr) {
    @rest = @curr[$best_offset + $best .. $#curr];
  }
  my @aligned = @rest;
  my $boundary = -1;
  for my $i (0 .. $#aligned) {
    if ($aligned[$i] =~ /^(?:\s*›\s|\s*•\s|\s*❯\s|\s*⏺\s|===== loglm start |\s*\(status\)\s*$)/) {
      $boundary = $i;
      last;
    }
  }
  if ($boundary > 0) {
    @rest = @aligned[$boundary .. $#aligned];
  }
  while (@rest && $rest[0] eq q{}) {
    shift @rest;
  }
  @curr = (@kept, @rest);
  $_ = join("\n", @curr);
  $_ .= "\n" if length($_);
}

if ($profile eq "codex") {
  my @lines = split /\n/, $_, -1;
  my $body = 0;
  for my $i (0 .. $#lines) {
    next unless $lines[$i] =~ /^===== loglm start /;
    $body = $i + 1;
    $body++ while $body < @lines && $lines[$body] eq q{};
    last;
  }

  my $first_compacted = -1;
  my $saw_action = 0;
  my $scan_limit = $body + 1200;
  $scan_limit = $#lines if $scan_limit > $#lines;
  for my $i ($body .. $scan_limit) {
    my $line = $lines[$i];
    if ($line =~ /Context compacted\b/) {
      $first_compacted = $i;
      last;
    }
    if ($line =~ /(?:Ran|Edited|Explored|Searched|List(?:ed)?|Read|Update|Created|Wrote|Waited)\b/) {
      $saw_action = 1;
      last;
    }
  }

  if ($first_compacted >= 0 && !$saw_action) {
    my @kept = ();
    if ($body > 0) {
      @kept = @lines[0 .. $body - 1];
    }
    my @rest = ();
    if ($first_compacted + 1 <= $#lines) {
      @rest = @lines[$first_compacted + 1 .. $#lines];
    }
    while (@rest && $rest[0] eq q{}) {
      shift @rest;
    }
    $_ = join("\n", @kept, @rest);
    $_ .= "\n" if length($_);
  }
}
' "$out_file"

  rm -f "$prev_tmp"
}

