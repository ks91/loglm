#!/usr/bin/env bash

set -euo pipefail

WORK_DIR="$(pwd -P)"
LOG_DIR="$WORK_DIR/logs"
AGENT_FILE="$WORK_DIR/.loglm_agent"
TODAY_LOCAL="$(date +%Y%m%d)"
NOW_LOCAL="$(date +%Y%m%d-%H%M%S)"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOGLM_HOME="${LOGLM_HOME:-$HOME/.local/share/loglm}"
SETUP_DIR=""
LOGLM_VERSION="0.1.3-dev"

SUPPORTED_AGENTS=(codex claude gemini)

usage() {
  cat <<'EOF'
Usage:
  loglm [options]
  loglm agent install <github_repo_or_url|local_repo_path> [--agent codex|claude|gemini|all]
  loglm agent list [--agent codex|claude|gemini|all]
  loglm agent remove <github_repo_or_url|local_repo_path> [--agent codex|claude|gemini|all]
  loglm agent update <github_repo_or_url|local_repo_path|--all> [--agent codex|claude|gemini|all]

Options:
  --new
      Start a new context (ignore saved session).
  --resume
      Open the agent's built-in session picker.
  --agent
      Re-select the AI coding agent (codex / claude / gemini).
  --daily-log
      Use one log file per day (legacy behavior).
      By default, loglm creates a unique file per launch (timestamp + PID).
  -X, --dangerous
      Start the agent in dangerous/no-approval mode:
        codex  : --dangerously-bypass-approvals-and-sandbox
        claude : --dangerously-skip-permissions
        gemini : --yolo
  -h, --help
      Show this help.
  -v, --version
      Show loglm version.

Subcommands:
  agent ...
      Manage prompt-agent blocks in AGENTS.md / CLAUDE.md / GEMINI.md.
EOF
}

show_version() {
  printf 'loglm %s\n' "$LOGLM_VERSION"
}

resolve_setup_dir() {
  if [[ -d "$SCRIPT_DIR/setup" ]]; then
    SETUP_DIR="$SCRIPT_DIR/setup"
    return 0
  fi
  if [[ -d "$LOGLM_HOME/setup" ]]; then
    SETUP_DIR="$LOGLM_HOME/setup"
    return 0
  fi
  return 1
}

ensure_agent_installed() {
  local agent="$1"
  if command -v "$agent" > /dev/null 2>&1; then
    return 0
  fi

  if ! resolve_setup_dir; then
    echo "Error: setup scripts not found." >&2
    echo "Expected '$SCRIPT_DIR/setup' or '$LOGLM_HOME/setup'." >&2
    echo "Reinstall loglm and try again." >&2
    exit 1
  fi

  "$SETUP_DIR/ensure-agent.sh" "$agent"
}

claude_has_history() {
  local encoded="${WORK_DIR//\//-}"
  compgen -G "$HOME/.claude/projects/$encoded/*.jsonl" > /dev/null 2>&1
}

is_running_under_script() {
  local pid ppid comm
  pid="$$"

  while :; do
    ppid="$(ps -o ppid= -p "$pid" | tr -d '[:space:]')"
    if [[ -z "$ppid" || "$ppid" == "0" ]]; then
      return 1
    fi

    comm="$(ps -o comm= -p "$ppid" | awk '{print $1}')"
    if [[ "$comm" == "script" ]]; then
      return 0
    fi

    pid="$ppid"
  done
}

run_agent_subcommand() {
  local subcmd="$1"
  shift
  if ! resolve_setup_dir; then
    echo "Error: setup scripts not found." >&2
    echo "Expected '$SCRIPT_DIR/setup' or '$LOGLM_HOME/setup'." >&2
    echo "Reinstall loglm and try again." >&2
    exit 1
  fi

  AGENT="${LOGLM_CODING_AGENT:-}"
  # For install, enforce coding-agent selection first.
  if [[ "$subcmd" == "install" ]]; then
    local skip_select=0
    for arg in "$@"; do
      if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
        skip_select=1
        break
      fi
    done

    if [[ "$skip_select" -eq 0 ]]; then
      if [[ -n "$AGENT" ]]; then
        valid=0
        for a in "${SUPPORTED_AGENTS[@]}"; do
          [[ "$a" == "$AGENT" ]] && valid=1 && break
        done
        if [[ "$valid" -eq 0 ]]; then
          echo "Warning: unknown agent '$AGENT' from LOGLM_CODING_AGENT. Re-selecting." >&2
          AGENT=""
        fi
      fi

      if [[ -z "$AGENT" && ! -f "$AGENT_FILE" ]]; then
        select_agent
      elif [[ -z "$AGENT" ]]; then
        AGENT="$(cat "$AGENT_FILE")"
        valid=0
        for a in "${SUPPORTED_AGENTS[@]}"; do
          [[ "$a" == "$AGENT" ]] && valid=1 && break
        done
        if [[ "$valid" -eq 0 ]]; then
          echo "Warning: unknown agent '$AGENT' stored in $AGENT_FILE. Re-selecting." >&2
          select_agent
        fi
      fi
    fi
  elif [[ -f "$AGENT_FILE" ]]; then
    AGENT="$(cat "$AGENT_FILE")"
  fi

  case "$subcmd" in
    install)
      LOGLM_DEFAULT_PROMPT_AGENT="$AGENT" "$SETUP_DIR/agent-install.sh" "$subcmd" "$@"
      ;;
    list|remove|update)
      LOGLM_DEFAULT_PROMPT_AGENT="$AGENT" "$SETUP_DIR/agent-install.sh" "$subcmd" "$@"
      ;;
    *)
      echo "Error: unknown agent subcommand: $subcmd" >&2
      usage >&2
      exit 2
      ;;
  esac
}

POST_INSTALL_NEW=0

select_agent() {
  echo "Select AI coding agent:"
  local i=1
  for agent in "${SUPPORTED_AGENTS[@]}"; do
    printf "  %d) %s\n" "$i" "$agent"
    ((i++))
  done
  local choice
  while :; do
    printf "Enter number [1-%d]: " "${#SUPPORTED_AGENTS[@]}"
    read -r choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#SUPPORTED_AGENTS[@]} )); then
      AGENT="${SUPPORTED_AGENTS[$((choice - 1))]}"
      printf '%s\n' "$AGENT" > "$AGENT_FILE"
      echo "Selected: $AGENT"
      return
    fi
    echo "Invalid choice. Please enter a number between 1 and ${#SUPPORTED_AGENTS[@]}."
  done
}

if (($# > 0)) && [[ "$1" == "agent" ]]; then
  shift
  if (($# == 0)); then
    usage >&2
    exit 2
  fi
  AGENT_SUBCMD="$1"
  AGENT_INSTALL_HELP=0
  if [[ "$AGENT_SUBCMD" == "install" ]]; then
    for arg in "$@"; do
      if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
        AGENT_INSTALL_HELP=1
        break
      fi
    done
  fi
  run_agent_subcommand "$@"
  if [[ "$AGENT_SUBCMD" != "install" ]]; then
    exit 0
  fi
  if [[ "$AGENT_INSTALL_HELP" -eq 1 ]]; then
    exit 0
  fi
  if [[ "${LOGLM_AGENT_INSTALL_NO_LAUNCH:-0}" == "1" ]]; then
    exit 0
  fi
  POST_INSTALL_NEW=1
  set --
fi

FORCE_NEW=0
CHOOSE_RESUME=0
DANGEROUS_MODE=0
CHOOSE_AGENT=0
DAILY_LOG=0

while (($# > 0)); do
  case "$1" in
    --new)
      FORCE_NEW=1
      shift
      ;;
    --resume)
      CHOOSE_RESUME=1
      shift
      ;;
    --agent)
      CHOOSE_AGENT=1
      shift
      ;;
    --daily-log)
      DAILY_LOG=1
      shift
      ;;
    -X|--dangerous)
      DANGEROUS_MODE=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -v|--version)
      show_version
      exit 0
      ;;
    *)
      echo "Error: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

mkdir -p "$LOG_DIR"

if [[ "$POST_INSTALL_NEW" -eq 1 ]]; then
  FORCE_NEW=1
fi

if [[ "$FORCE_NEW" -eq 1 && "$CHOOSE_RESUME" -eq 1 ]]; then
  echo "Error: --new and --resume cannot be used together." >&2
  exit 2
fi

if [[ "$CHOOSE_AGENT" -eq 1 || ! -f "$AGENT_FILE" ]]; then
  select_agent
else
  AGENT="$(cat "$AGENT_FILE")"
  valid=0
  for a in "${SUPPORTED_AGENTS[@]}"; do
    [[ "$a" == "$AGENT" ]] && valid=1 && break
  done
  if [[ "$valid" -eq 0 ]]; then
    echo "Warning: unknown agent '$AGENT' stored in $AGENT_FILE. Re-selecting." >&2
    select_agent
  fi
fi

ensure_agent_installed "$AGENT"

if [[ "$DAILY_LOG" -eq 1 ]]; then
  LOG_FILE="$LOG_DIR/loglm-${AGENT}-log-${TODAY_LOCAL}.txt"
else
  LOG_FILE="$LOG_DIR/loglm-${AGENT}-log-${NOW_LOCAL}-pid$$.txt"
fi

case "$AGENT" in
  codex)
    BASE_CMD=(codex)
    if [[ "$DANGEROUS_MODE" -eq 1 ]]; then
      BASE_CMD+=(--dangerously-bypass-approvals-and-sandbox)
    fi
    if [[ "$FORCE_NEW" -eq 1 ]]; then
      AGENT_CMD=("${BASE_CMD[@]}" --search)
    elif [[ "$CHOOSE_RESUME" -eq 1 ]]; then
      AGENT_CMD=("${BASE_CMD[@]}" resume)
    else
      AGENT_CMD=("${BASE_CMD[@]}" resume --last)
    fi
    ;;

  claude)
    BASE_CMD=(claude)
    if [[ "$DANGEROUS_MODE" -eq 1 ]]; then
      BASE_CMD+=(--dangerously-skip-permissions)
    fi
    if [[ "$FORCE_NEW" -eq 1 ]]; then
      AGENT_CMD=("${BASE_CMD[@]}")
    elif [[ "$CHOOSE_RESUME" -eq 1 ]]; then
      AGENT_CMD=("${BASE_CMD[@]}" --resume)
    elif claude_has_history; then
      AGENT_CMD=("${BASE_CMD[@]}" --continue)
    else
      AGENT_CMD=("${BASE_CMD[@]}")
    fi
    ;;

  gemini)
    BASE_CMD=(gemini)
    if [[ "$DANGEROUS_MODE" -eq 1 ]]; then
      BASE_CMD+=(--yolo)
    fi
    if [[ "$FORCE_NEW" -eq 1 ]]; then
      AGENT_CMD=("${BASE_CMD[@]}")
    else
      AGENT_CMD=("${BASE_CMD[@]}" --resume)
    fi
    ;;
esac

if is_running_under_script; then
  exec "${AGENT_CMD[@]}"
fi

RUN_START_LOCAL="$(date '+%Y-%m-%d %H:%M:%S %z')"
{
  printf '\n===== loglm start [%s]: %s =====\n' "$AGENT" "$RUN_START_LOCAL"
} >> "$LOG_FILE"

SCRIPT_OPTS=(-q -a)
SCRIPT_HELP="$(script -h 2>&1 || true)"

if printf '%s' "$SCRIPT_HELP" | grep -Eq -- '(^|[[:space:]])-F([,[:space:]]|$)'; then
  SCRIPT_OPTS+=(-F)
elif printf '%s' "$SCRIPT_HELP" | grep -Eq -- '(^|[[:space:]])-f([,[:space:]]|$)'; then
  SCRIPT_OPTS+=(-f)
fi

if printf '%s' "$SCRIPT_HELP" | grep -Eq -- '(^|[[:space:]])-c,|--command([[:space:]]|=)'; then
  AGENT_CMD_STRING="$(printf '%q ' "${AGENT_CMD[@]}")"
  AGENT_CMD_STRING="${AGENT_CMD_STRING% }"
  exec script "${SCRIPT_OPTS[@]}" "$LOG_FILE" -c "exec $AGENT_CMD_STRING"
else
  exec script "${SCRIPT_OPTS[@]}" "$LOG_FILE" "${AGENT_CMD[@]}"
fi
